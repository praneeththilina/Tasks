# Copy this to .env for LOCAL TESTING ONLY (e.g. with `python-dotenv` or
# `export $(cat .env | xargs)`). On Render, set these in the dashboard
# under your service's Environment tab instead — do not commit real values.

TELEGRAM_BOT_TOKEN=paste_your_telegram_bot_token_here
WEBHOOK_SECRET=change_me_long_random_string
CRON_SECRET=change_me_different_long_random_string
SETUP_PASSWORD=your-private-one-time-claim-password

# Supabase connection string — use the "Transaction pooler" connection
# string from Supabase (Project Settings -> Database -> Connection string),
# port 6543, not the direct port-5432 connection.
DATABASE_URL=postgresql://postgres.xxxxxxxx:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres

DEFAULT_AI_PROVIDER=opencode
DEFAULT_OPENCODE_MODEL=big-pickle
DEFAULT_OPENCODE_API_KEY=paste_your_opencode_zen_api_key_here
DEFAULT_GEMINI_MODEL=gemini-2.5-flash
DEFAULT_GEMINI_API_KEY=
